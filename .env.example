# ─────────────────────────────────────────────
# E-Commerce Chatbot — Environment Configuration
# Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────

# ── LLM Provider (set ONE of these) ──────────
# Option 1: Anthropic Claude (recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 2: OpenAI
# OPENAI_API_KEY=your_openai_api_key_here

# Option 3: Ollama (no key needed, install Ollama + run `ollama pull llama3.2`)
# No env var needed — Ollama auto-detected as last fallback


# ── LangSmith (optional but recommended) ─────
# Get your key at: https://smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=ecommerce-chatbot
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Your LangSmith Hub username (for prompt management)
LANGSMITH_HUB_USER=your_langsmith_username


# ── App Settings ──────────────────────────────
ENVIRONMENT=development
DB_PATH=ecommerce.db
DEBUG=false
